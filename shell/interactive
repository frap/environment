# -*- mode: sh; -*-

[[ "$TERM" == "dumb" && "$INSIDE_EMACS" ]] && ssource "$XDG_CONFIG_HOME/shell/emacs_shell" && return

export NAME='Andrés Gasson'
export EMAIL='gas@tuatara.red'
export PAGER='less'
export EDITOR='emacsclient -nw -a ""'
export VISUAL="$EDITOR"

[[ -r "$XDG_CONFIG_HOME/shell/aliases" ]] && . "$XDG_CONFIG_HOME/shell/aliases"
# [[ -r "$XDG_CONFIG_HOME/shell/interactive_fns" ]] && . "$XDG_CONFIG_HOME/shell/interactive_fns"

if [[ "$CPUCOUNT" -gt 1 ]]; then
  export MAKEFLAGS="-j$CPUCOUNT"
  export DEVENV_MAX_JOBS="$CPUCOUNT"
  export DEVENV_CORES="$CPUCOUNT"
fi

mesg n 2>/dev/null || true
